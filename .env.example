# LLM provider selection:
# Choose from: openai | anthropic | gemini | openai_compatible
LLM_PROVIDER=openai

# Model id for selected provider
# Examples: gpt-4o, claude-3-5-sonnet-latest, gemini-1.5-pro, qwen/qwen3-32b
LLM_MODEL=gpt-4o

# Optional custom base URL (useful for gateways or self-hosted OpenAI-compatible APIs)
# LLM_BASE_URL=https://api.groq.com/openai/v1

# Provider API keys (uncomment the one you use):
# OPENAI_API_KEY=sk-proj-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AIza...

# Generic key for 'openai_compatible' provider
# LLM_API_KEY=your-api-key-here

# Bot settings
BOT_NAME=TaskBot
COMMAND_PREFIX=!
CONFIDENCE_THRESHOLD=0.7

# Allowed WhatsApp group IDs (comma-separated)
# Leave blank to allow any group, or find these from the Baileys terminal logs when a message is received
ALLOWED_GROUPS=

# Dashboard settings
JWT_SECRET=super-secret-jwt-key
DASHBOARD_PORT=3001
